{
  "name": "@wst7/gum",
  "version": "1.0.2",
  "description": "Git User Manager - Switch between git users easily",
  "author": "wst7",
  "bin": {
    "gum": "./dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "scripts": {
    "prepublishOnly": "bunli build",
    "postinstall": "bunli generate",
    "dev": "bun run src/index.ts",
    "build": "bunli build",
    "typecheck": "npx tsc --noEmit",
    "release": "release-it"
  },
  "dependencies": {
    "@bunli/core": "^0.9.1",
    "ini": "^7.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@bunli/test": "^0.6.0",
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "^1.3.14",
    "@types/ini": "^4.1.1",
    "bunli": "^0.9.1",
    "release-it": "^20.0.1",
    "typescript": "^6.0.3"
  },
  "bunli": {
    "entry": "./src/index.ts",
    "outDir": "./dist"
  }
}
