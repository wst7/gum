{
  "name": "@wst7/gum",
  "version": "1.1.8",
  "description": "Git User Manager - Switch between git users easily",
  "author": "wst7",
  "bin": {
    "gum": "dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bunli build",
    "build:all": "bunli build --targets all --outdir ./binaries",
    "typecheck": "npx tsc --noEmit",
    "release": "release-it"
  },
  "dependencies": {
    "@bunli/core": "^0.9.1",
    "ini": "^7.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@bunli/test": "^0.6.0",
    "@release-it/conventional-changelog": "^11.0.0",
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "^1.3.14",
    "@types/ini": "^4.1.1",
    "bunli": "^0.9.1",
    "release-it": "^20.0.1",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wst7/gum.git"
  }
}
