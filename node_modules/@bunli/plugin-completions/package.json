{
  "name": "@bunli/plugin-completions",
  "version": "0.3.5",
  "description": "Shell completions plugin for Bunli CLI framework",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts && bun run tsgo",
    "test": "bun test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@bunli/core": "^0.9.0",
    "better-result": "^2.7.0"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.10",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "bunli",
    "cli",
    "completions",
    "bash",
    "zsh",
    "fish",
    "shell"
  ],
  "author": "Bunli Team",
  "license": "MIT"
}
