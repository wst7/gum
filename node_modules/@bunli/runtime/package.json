{
  "name": "@bunli/runtime",
  "version": "0.3.2",
  "description": "Runtime renderer and prompt primitives for Bunli",
  "keywords": [
    "bunli",
    "prompt",
    "runtime",
    "terminal",
    "tui"
  ],
  "license": "MIT",
  "author": "Bunli Contributors",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "default": "./src/app.ts"
    },
    "./renderer": {
      "types": "./dist/renderer.d.ts",
      "default": "./src/renderer.tsx"
    },
    "./prompt": {
      "types": "./dist/prompt/index.d.ts",
      "default": "./src/prompt/index.ts"
    },
    "./options": {
      "types": "./dist/options.d.ts",
      "default": "./src/options.ts"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "default": "./src/events.ts"
    },
    "./transport": {
      "types": "./dist/transport.d.ts",
      "default": "./src/transport.ts"
    },
    "./image": {
      "types": "./dist/image/index.d.ts",
      "default": "./src/image/index.ts"
    }
  },
  "scripts": {
    "build": "bun run scripts/build.ts && tsgo",
    "test": "bun test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@opentui/core": "0.1.97",
    "@opentui/react": "0.1.97",
    "@standard-schema/spec": "^1.1.0",
    "@standard-schema/utils": "^0.3.0",
    "better-result": "^2.7.0",
    "debug": "^4.4.3",
    "fuse.js": "^7.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.10",
    "@types/debug": "^4.1.13",
    "@types/react": "19.2.14",
    "react": "^19.2.4",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@opentui/core": "0.1.97",
    "react": "^19.2.4"
  }
}
