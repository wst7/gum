{
  "name": "@bunli/tui",
  "version": "0.6.0",
  "description": "Terminal User Interface plugin for Bunli CLI framework",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./inline": {
      "types": "./dist/inline/index.d.ts",
      "default": "./src/inline/index.ts"
    },
    "./interactive": {
      "types": "./dist/interactive/index.d.ts",
      "default": "./src/interactive/index.tsx"
    },
    "./charts": {
      "types": "./dist/charts/index.d.ts",
      "default": "./src/charts/index.tsx"
    },
    "./utils/sync-batcher": {
      "types": "./dist/utils/sync-batcher.d.ts",
      "default": "./src/utils/sync-batcher.ts"
    }
  },
  "scripts": {
    "build": "bun run scripts/build.ts && tsgo",
    "test": "bun test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@bunli/runtime": "^0.3.0",
    "@opentui/core": "^0.1.90",
    "@opentui/react": "^0.1.90",
    "@standard-schema/spec": "^1.1.0",
    "@standard-schema/utils": "^0.3.0",
    "debug": "^4.4.3",
    "fuse.js": "^7.1.0"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.10",
    "@types/react": "19.2.14",
    "react": "^19.2.4",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@opentui/core": "^0.1.90",
    "react": "^19.2.4"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "bunli",
    "cli",
    "tui",
    "terminal",
    "ui",
    "interactive"
  ],
  "author": "Bunli Contributors",
  "license": "MIT"
}
